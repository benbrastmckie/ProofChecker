% ============================================================================
% logos-notation.sty
% Notation package for Logos logic system documentation
%
% Based on recursive-semantics.md specification
% Compatible with LaTeX, markdown, and Lean notation conventions
%
% Imports shared notation from ../../../latex/notation-standards.sty
% (found via TEXINPUTS configured in latexmkrc)
% ============================================================================

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{logos-notation}[2026/01/11 Logos Logic Notation]

% ============================================================================
% Import Shared Notation Standards
% ============================================================================

\RequirePackage{notation-standards}

% Additional required packages for Logos-specific notation
\RequirePackage{stmaryrd}  % for \llbracket, \rrbracket
\RequirePackage{mathabx}    % for \square, \sqbullet symbols

% ============================================================================
% Constitutive Foundation (Logos-specific)
% ============================================================================

% --- State Space ---
\newcommand{\statespace}{\mathcal{S}}
\newcommand{\nullstate}{\square}
\newcommand{\fullstate}{\sqbullet}
\newcommand{\fusion}[2]{#1\sqcup#2}
\newcommand{\Fusion}{\bigsqcup}
\newcommand{\parthood}{\sqsubseteq}
\newcommand{\strictpart}{\sqsubset}

% --- Verification and Falsification ---
\newcommand{\verifies}{\Vdash}
\newcommand{\falsifies}{\dashV}
\newcommand{\verifierset}[1]{|{#1}|^+}
\newcommand{\falsifierset}[1]{|{#1}|^-}
\newcommand{\verifiertype}[1]{|{#1}|^+}
\newcommand{\falsifiertype}[1]{|{#1}|^-}

% --- Type Notation ---
% These commands match Lean notation exactly for reader consistency
\newcommand{\Set}{\mathsf{Set}}      % Set constructor (matches Lean notation)
\newcommand{\powerset}{\mathcal{P}}    % Power set notation
\newcommand{\Fin}{\mathtt{Fin}}      % Finite set notation
\newcommand{\Term}{\mathsf{Term}}     % Term type (matches Lean notation)
\newcommand{\Formula}{\mathsf{Formula}} % Formula type (matches Lean notation)
\newcommand{\set}[1]{\{#1\}}          % Set notation (replaces \{...\} pairs)

% --- Bilateral Proposition Notation ---
\newcommand{\prop}[1]{\mathsf{#1}} % Use \prop for bilateral propositions
\newcommand{\props}{\mathbb{P}} % Use \props for space of bilateral propositions
\newcommand{\Prop}{\mathsf{Prop}} % Use \Prop for the type Prop in Lean

% --- Derived Relations ---
\newcommand{\essence}{\sqsubseteq}
\newcommand{\ground}{\leq}

% --- Inductive Definition Syntax ---
\newcommand{\Define}{\Coloneq}         % BNF-style definition (::=)
% Note: \define is \coloneqq (:=) from notation-standards.sty

% --- Free Variables ---
\newcommand{\FV}{\mathsf{FV}}           % Free variables function

% --- Variable Assignment ---
\newcommand{\assignment}{\sigma}
\newcommand{\assignsub}[2]{\sigma[#1/#2]}
\newcommand{\sem}[1]{\llbracket #1 \rrbracket}

% ============================================================================
% Core Extension (Logos-specific)
% ============================================================================

% --- Temporal Order ---
\newcommand{\temporalorder}{\mathcal{D}}
\newcommand{\timelt}{<}
\newcommand{\timeleq}{\leq}

% --- Task Relation ---
\newcommand{\task}[3]{#1 \Rightarrow_{#2} #3}
\newcommand{\taskrel}{\Rightarrow}

% --- State Modality ---
\newcommand{\possible}{P}
\newcommand{\compatible}{\circ}
\newcommand{\connected}{\sim}
\newcommand{\worldstates}{W}
\newcommand{\necessary}{N}
\newcommand{\maxcompat}[2]{[#1]_{#2}}
\newcommand{\altworlds}[3]{\langle #1 \rangle_{#2}^{#3}}

% --- World-History ---
\newcommand{\history}{\tau}
\newcommand{\historyspace}{H_\mathcal{F}}

% --- Temporal Index ---
\newcommand{\tempindex}{\vec{\imath}}

% --- Core Tense Operators ---
\newcommand{\allpast}{H}           % always past
\newcommand{\allfuture}{G}       % always future
\newcommand{\somepast}{P}          % some past
\newcommand{\somefuture}{F}       % some future

% --- Derived Tense Operators ---
\newcommand{\always}{\ensuremath \raisebox{-1.3pt}{$\triangle$}}
\newcommand{\sometimes}{\ensuremath \raisebox{1.3pt}{\rotatebox[origin=c]{180}{$\triangle$}}}

% --- Extended Tense Operators ---
\newcommand{\since}{\triangleleft}
\newcommand{\until}{\triangleright}

% --- Counterfactual ---
% \boxright, \diamondright, \circleright, \dotcircleright provided by notation-standards.sty
\newcommand{\imposition}[2]{#1 \to_{#2}}

% --- Store/Recall ---
\newcommand{\store}[1]{\uparrow^{#1}\hspace{-2pt}}
\newcommand{\recall}[1]{\downarrow^{#1}\hspace{-2pt}}

% --- Actuality ---
\newcommand{\actual}{\mathsf{Act}}

% ============================================================================
% Model Notation (Logos-specific extensions)
% ============================================================================

\newcommand{\mframe}{\mathcal{F}}
% \model is provided by notation-standards.sty
\newcommand{\interp}[1]{|#1|}

% ============================================================================
% Meta-Variables (Logos-specific extensions)
% ============================================================================

\newcommand{\metaA}{\varphi}
\newcommand{\metaB}{\psi}
\newcommand{\metaC}{\chi}
% \metaphi, \metapsi, \metachi provided by notation-standards.sty

% ============================================================================
% Type Notation
% ============================================================================

\newcommand{\bool}{\mathscr{bool}}            % Model symbol

% ============================================================================
% End of Package
% ============================================================================
