{
  "$schema": "https://opencode.ai/config.json",
  "tools": {
    "lean-lsp-mcp*": false
  },
  "agent": {
    "latex-research": {
      "tools": {
        "edit": true,
        "glob": true,
        "grep": true,
        "websearch": true,
        "webfetch": true,
        "bash": true,
        "read": true,
        "write": true
      },
      "description": "Research LaTeX documentation and formatting topics",
      "prompt": "{file:.opencode/agent/subagents/latex-research-agent.md}",
      "mode": "subagent"
    },
    "latex-implementation": {
      "tools": {
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "read": true,
        "write": true
      },
      "description": "Implement LaTeX documents and formatting",
      "prompt": "{file:.opencode/agent/subagents/latex-implementation-agent.md}",
      "mode": "subagent"
    },
    "typst-implementation": {
      "mode": "subagent",
      "description": "Implement Typst documents and formatting",
      "prompt": "{file:.opencode/agent/subagents/typst-implementation-agent.md}",
      "tools": {
        "edit": true,
        "glob": true,
        "grep": true,
        "read": true,
        "bash": true,
        "write": true
      }
    },
    "lean-research-agent": {
      "tools": {
        "lean-lsp-mcp_leansearch": true,
        "lean-lsp-mcp_local_search": true,
        "lean-lsp-mcp_leanfinder": true,
        "lean-lsp-mcp_state_search": true,
        "lean-lsp-mcp_loogle": true
      },
      "mode": "subagent"
    },
    "lean-implementation-agent": {
      "tools": {
        "lean-lsp-mcp_goal": true,
        "lean-lsp-mcp_build": true,
        "lean-lsp-mcp_term_goal": true,
        "lean-lsp-mcp_diagnostic_messages": true,
        "lean-lsp-mcp_run_code": true,
        "lean-lsp-mcp_hover_info": true,
        "lean-lsp-mcp_file_outline": true
      },
      "mode": "subagent"
    },
    "lean-implementation": {
      "prompt": "{file:.opencode/agent/subagents/lean-implementation-agent.md}",
      "description": "Implement Lean 4 proofs and definitions",
      "tools": {
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "read": true,
        "write": true
      },
      "mode": "subagent"
    },
    "lean-research": {
      "prompt": "{file:.opencode/agent/subagents/lean-research-agent.md}",
      "description": "Research Lean 4 theorem proving and Mathlib",
      "tools": {
        "edit": true,
        "glob": true,
        "grep": true,
        "webfetch": true,
        "bash": true,
        "websearch": true,
        "read": true,
        "write": true
      },
      "mode": "subagent"
    },
    "math-research": {
      "mode": "subagent",
      "description": "Research mathematics and abstract algebra topics",
      "tools": {
        "edit": true,
        "glob": true,
        "grep": true,
        "webfetch": true,
        "bash": true,
        "websearch": true,
        "read": true,
        "write": true
      },
      "prompt": "{file:.opencode/agent/subagents/math-research-agent.md}"
    },
    "logic-research": {
      "mode": "subagent",
      "description": "Research mathematical logic and proof theory",
      "tools": {
        "edit": true,
        "glob": true,
        "grep": true,
        "webfetch": true,
        "bash": true,
        "websearch": true,
        "read": true,
        "write": true
      },
      "prompt": "{file:.opencode/agent/subagents/logic-research-agent.md}"
    },
    "physics-research": {
      "mode": "subagent",
      "description": "Research physics and mathematical physics topics",
      "tools": {
        "edit": true,
        "glob": true,
        "grep": true,
        "webfetch": true,
        "bash": true,
        "websearch": true,
        "read": true,
        "write": true
      },
      "prompt": "{file:.opencode/agent/subagents/physics-research-agent.md}"
    },
    "formal-research": {
      "mode": "subagent",
      "description": "Research formal methods and verification topics",
      "tools": {
        "edit": true,
        "glob": true,
        "grep": true,
        "webfetch": true,
        "bash": true,
        "websearch": true,
        "read": true,
        "write": true
      },
      "prompt": "{file:.opencode/agent/subagents/formal-research-agent.md}"
    },
    "typst-research": {
      "mode": "subagent",
      "description": "Research Typst documentation and formatting topics",
      "prompt": "{file:.opencode/agent/subagents/typst-research-agent.md}",
      "tools": {
        "edit": true,
        "glob": true,
        "grep": true,
        "webfetch": true,
        "read": true,
        "websearch": true,
        "bash": true,
        "write": true
      }
    }
  },
  "mcp": {
    "lean-lsp-mcp": {
      "type": "local",
      "timeout": 10000,
      "environment": {
        "LEAN_PROJECT_ROOT": "{env:PWD}"
      },
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "lean-lsp-mcp"
      ]
    }
  },
  "default_agent": "orchestrator"
}
