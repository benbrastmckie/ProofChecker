{
  "mcp": {
    "lean-lsp-mcp": {
      "environment": {
        "LEAN_PROJECT_ROOT": "{env:PWD}"
      },
      "timeout": 10000,
      "command": [
        "npx",
        "-y",
        "lean-lsp-mcp"
      ],
      "type": "local",
      "enabled": true
    }
  },
  "tools": {
    "lean-lsp-mcp*": false
  },
  "default_agent": "orchestrator",
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "physics-research": {
      "description": "Research physics and mathematical physics topics",
      "tools": {
        "grep": true,
        "glob": true,
        "webfetch": true,
        "bash": true,
        "websearch": true,
        "write": true,
        "edit": true,
        "read": true
      },
      "prompt": "{file:.opencode/agent/subagents/physics-research-agent.md}",
      "mode": "subagent"
    },
    "document": {
      "description": "Convert and process document files (DOCX, PDF, etc.)",
